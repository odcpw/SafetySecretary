# Also powers the incident-coach push-to-talk voice input
# (OpenAI gpt-4o-transcribe). Tenant BYOK key is used first when configured.
OPENAI_API_KEY=
APP_BASE_URL=http://localhost:3000
DATABASE_URL="postgresql://safety_secretary:safety_secretary@localhost:5432/safety_secretary"
LLM_BASE_URL=
LLM_API_KEY=
LLM_TEXT_MODEL=
LLM_VISION_MODEL=
SELF_HOST_PER_COMPANY_CAP_USD=
LLM_VALIDATION_OK=
# Backs BYOK ciphertext and the session-bound CSRF token HMAC. Required in
# production (a 32-byte key); non-production falls back to a dev key when unset.
MASTER_ENCRYPTION_KEY=
STORAGE_DRIVER=local-fs
STORAGE_LOCAL_ROOT=.data/storage
EMAIL_TRANSPORT=dev
EMAIL_FROM=no-reply@safetysecretary.local
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=
MAGIC_LINK_DEV_EMAIL_LOG=/tmp/safety-secretary-next-magic-links.jsonl
# Microsoft OAuth requires Azure optional ID-token claims: email and xms_edov.
# Microsoft consumer accounts without xms_edov should use magic links.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
MICROSOFT_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
NEXT_PUBLIC_MICROSOFT_OAUTH_ENABLED=0
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=0
SSFW_DEV_AUTH_BYPASS=0
NEXT_PUBLIC_SSFW_DEV_AUTH_BYPASS=0
SSFW_DEV_AUTH_EMAIL=tester@safetysecretary.local
SSFW_DEV_AUTH_COMPANY_NAME="Safety Secretary Test Workspace"
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
# Live II coach runtime. Default is the durable Flue agent, which runs as a
# SEPARATE server process — start it with `pnpm flue:start` (or `pnpm flue:dev`)
# alongside `pnpm dev`, and give that process OPENAI_API_KEY. There is no silent
# fallback: if the Flue server is unreachable, coach turns hard-fail. Set this to
# `pi` for the in-process path (no extra server; falls back to OpenAI directly).
SSFW_II_COACH_RUNTIME=flue
# Model for the `pi` runtime path only.
SSFW_PI_MODEL=openai/gpt-5.2
SSFW_PI_SDK_MODULE_PATH=
SSFW_FLUE_BASE_URL=http://127.0.0.1:3583
SSFW_FLUE_TOKEN=
SSFW_FLUE_II_AGENT=incident-investigation
# Model the Flue coach runs on. Set explicitly so SSFW_PI_MODEL / LLM_TEXT_MODEL
# can't leak into the Flue server and silently downgrade the coach.
SSFW_FLUE_MODEL=openai/gpt-5.5
SSFW_FLUE_SQLITE_PATH=./data/flue.db
SSFW_FLUE_STREAM_RETENTION_HOURS=24
SSFW_FLUE_PRUNE_VACUUM=0
SSFW_II_TRANSCRIBE_MODEL=
